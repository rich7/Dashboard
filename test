let data = (() => { try { const s = localStorage.getItem(STORAGE_KEY); return s ? JSON.parse(s) : defaultData(); } catch { return defaultData(); } })();
function save() { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch {} }

// ─── Tabs ──────────────────────────────────────────────────────────────────
let activeTab = 0;
document.getElementById('tab-bar').addEventListener('click', e => {
  const btn = e.target.closest('.tab');
  if (!btn) return;
  activeTab = +btn.dataset.tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', +t.dataset.tab === activeTab));
  document.querySelectorAll('.tab-panel').forEach((p,i) => p.classList.toggle('active', i === activeTab));
  document.getElementById('widget-col').classList.toggle('hidden', activeTab !== 0);
});

// ─── Render Blocks ─────────────────────────────────────────────────────────
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function renderBlocks() {
  [0,1].forEach(ti => {
    const grid = document.getElementById('grid-'+ti);
    if (!grid) return;
    if (grid._sortable) { grid._sortable.destroy(); grid._sortable = null; }
    grid.innerHTML = '';
    data.tabs[ti].blocks.forEach(block => {
      const div = document.createElement('div');
      div.className = 'link-block';
      div.dataset.id = block.id;
      const links = block.links.map(l => `
        <a class="link-item" href="${esc(l.url)}" target="_blank" rel="noopener">
          <img class="link-item-favicon" src="https://www.google.com/s2/favicons?domain=${encodeURIComponent(l.url)}&sz=32" onerror="this.style.display='none'" loading="lazy">
          <span class="link-item-name">${esc(l.name)}</span>
        </a>`).join('');
      div.innerHTML = `
        <div class="block-header">
          <div class="block-title-wrap">
            <span class="drag-handle" title="Verplaats blok">⠿</span>
            <span class="block-emoji">${block.emoji||'🔗'}</span>
            <span class="block-title">${esc(block.title)}</span>
          </div>
          <div class="block-actions">
            <button class="btn-icon open-all" onclick="openAll('${block.id}',${ti})">Alles</button>
            <button class="btn-icon edit-btn" onclick="openEdit('${block.id}',${ti})">✎ Edit</button>
          </div>
        </div>
        <div class="block-links">${links || '<div class="add-first-link">Geen links — klik Edit</div>'}</div>`;
      grid.appendChild(div);
    });
    grid._sortable = Sortable.create(grid, {
      handle: '.drag-handle', animation: 160,
      ghostClass: 'sortable-ghost', chosenClass: 'sortable-chosen',
      onEnd: evt => {
        const blocks = data.tabs[ti].blocks;
        const moved = blocks.splice(evt.oldIndex, 1)[0];
        blocks.splice(evt.newIndex, 0, moved);
        save();
      }
    });
  });
}

function openAll(blockId, tabIdx) {
  const block = data.tabs[tabIdx].blocks.find(b => b.id === blockId);
  if (!block) return;
  block.links.forEach((l, i) => setTimeout(() => { try { window.open(l.url,'_blank','noopener'); } catch {} }, i * 100));
}

// ─── Add / Edit Block ──────────────────────────────────────────────────────
let editingTabIdx = null, editingBlockId = null;

function openAddBlock(ti) {
  editingTabIdx = ti; editingBlockId = null;
  document.getElementById('modal-title-txt').textContent = 'Nieuw blok';
  document.getElementById('edit-emoji').value = '🔗';
  document.getElementById('edit-title').value = '';
  document.getElementById('link-edit-list').innerHTML = '';
  document.getElementById('btn-delete-block').style.display = 'none';
  document.getElementById('edit-modal').classList.remove('hidden');
}

function openEdit(blockId, ti) {
  const block = data.tabs[ti].blocks.find(b => b.id === blockId);
  if (!block) return;
  editingTabIdx = ti; editingBlockId = blockId;
  document.getElementById('modal-title-txt').textContent = 'Blok bewerken';
  document.getElementById('edit-emoji').value = block.emoji||'🔗';
  document.getElementById('edit-title').value = block.title;
  document.getElementById('link-edit-list').innerHTML = '';
  block.links.forEach(l => addLinkRow(l.name, l.url));
  document.getElementById('btn-delete-block').style.display = 'block';
  document.getElementById('edit-modal').classList.remove('hidden');
}

function addLinkRow(name='', url='') {
  const row = document.createElement('div');
  row.className = 'link-edit-item';
  row.innerHTML = `
    <input type="text" placeholder="Naam" value="${esc(name)}">
    <input type="url" placeholder="https://..." value="${esc(url)}">
    <button class="btn-del-link" onclick="this.parentElement.remove()">✕</button>`;
  document.getElementById('link-edit-list').appendChild(row);
}

function saveBlock() {
  const emoji = document.getElementById('edit-emoji').value.trim()||'🔗';
  const title = document.getElementById('edit-title').value.trim()||'Nieuw blok';
  const links = [...document.getElementById('link-edit-list').querySelectorAll('.link-edit-item')].map(row => {
    const [n,u] = row.querySelectorAll('input');
    return n.value.trim() && u.value.trim() ? {name:n.value.trim(),url:u.value.trim()} : null;
  }).filter(Boolean);
  if (editingBlockId) {
    const b = data.tabs[editingTabIdx].blocks.find(b => b.id === editingBlockId);
    if (b) { b.emoji=emoji; b.title=title; b.links=links; }
  } else {
    data.tabs[editingTabIdx].blocks.push({id:uid(),emoji,title,links});
  }
  save(); renderBlocks(); closeModal();
}

function deleteBlock() {
  if (!editingBlockId) return;
  data.tabs[editingTabIdx].blocks = data.tabs[editingTabIdx].blocks.filter(b => b.id !== editingBlockId);
  save(); renderBlocks(); closeModal();
}

function closeModal() { document.getElementById('edit-modal').classList.add('hidden'); }
document.getElementById('edit-modal').addEventListener('click', e => { if (e.target===e.currentTarget) closeModal(); });

// ─── Notes ────────────────────────────────────────────────────────────────
function renderNotes() {
  const grid = document.getElementById('notes-grid');
  grid.innerHTML = '';
  data.notes.forEach(note => {
    const card = document.createElement('div');
    card.className = 'note-card';
    const updated = new Date(note.updated).toLocaleString('nl-NL',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});
    card.innerHTML = `
      <div class="note-header">
        <input class="note-title-input" placeholder="Titel…" value="${esc(note.title)}" oninput="updateNote('${note.id}','title',this.value)">
      </div>
      <textarea class="note-textarea" placeholder="Schrijf hier…" oninput="updateNote('${note.id}','body',this.value)">${esc(note.body)}</textarea>
      <div class="note-footer">
        <span>Bijgewerkt: ${updated}</span>
        <button class="btn-del-note" onclick="deleteNote('${note.id}')">Verwijder</button>
      </div>`;
    grid.appendChild(card);
  });
}

function addNote() {
  data.notes.unshift({id:uid(),title:'',body:'',updated:Date.now()});
  save(); renderNotes();
  setTimeout(() => document.querySelector('.note-title-input')?.focus(), 50);
}
function updateNote(id,field,val) {
  const n = data.notes.find(n=>n.id===id);
  if (n) { n[field]=val; n.updated=Date.now(); save(); }
  const card = document.querySelector(`[oninput*="${id}"]`)?.closest('.note-card');
  if (card) { const f=card.querySelector('.note-footer span'); if(f) f.textContent='Bijgewerkt: '+new Date().toLocaleString('nl-NL',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}); }
}
function deleteNote(id) { data.notes=data.notes.filter(n=>n.id!==id); save(); renderNotes(); }

// ─── Clock ────────────────────────────────────────────────────────────────
const DAYS_NL=['zondag','maandag','dinsdag','woensdag','donderdag','vrijdag','zaterdag'];
const MONTHS_NL=['januari','februari','maart','april','mei','juni','juli','augustus','september','oktober','november','december'];

function updateClock() {
  const now = new Date();
  const h=String(now.getHours()).padStart(2,'0'), m=String(now.getMinutes()).padStart(2,'0');
  const timeStr=`${h}:${m}`;
  document.getElementById('clock-time').textContent=timeStr;
  document.getElementById('clock-date').textContent=`${DAYS_NL[now.getDay()]} ${now.getDate()} ${MONTHS_NL[now.getMonth()]} ${now.getFullYear()}`;
  document.getElementById('datetime-mini').innerHTML=timeStr+'<br>'+`${now.getDate()} ${MONTHS_NL[now.getMonth()].slice(0,3)}`;
}
setInterval(updateClock, 5000); updateClock();

// ─── Timer ────────────────────────────────────────────────────────────────
let timerSeconds=0, timerInterval=null, timerCountdown=false;

function updateTimerDisplay() {
  const m=Math.floor(Math.abs(timerSeconds)/60), s=Math.abs(timerSeconds)%60;
  document.getElementById('timer-display').textContent=(timerSeconds<0?'-':'')+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
}

function setTimer(minutes) {
  clearInterval(timerInterval); timerInterval=null;
  timerSeconds=minutes*60; timerCountdown=true;
  document.getElementById('timer-start').classList.remove('active');
  updateTimerDisplay();
}

function setTimerCustom() {
  const m=Math.max(0,Math.min(99,parseInt(document.getElementById('timer-custom-m').value)||0));
  const s=Math.max(0,Math.min(59,parseInt(document.getElementById('timer-custom-s').value)||0));
  if (m===0&&s===0) return;
  clearInterval(timerInterval); timerInterval=null;
  timerSeconds=m*60+s; timerCountdown=true;
  document.getElementById('timer-start').classList.remove('active');
  document.getElementById('timer-custom-m').value='';
  document.getElementById('timer-custom-s').value='';
  updateTimerDisplay();
}

document.getElementById('timer-start').addEventListener('click', () => {
  if (timerInterval) return;
  document.getElementById('timer-start').classList.add('active');
  timerInterval=setInterval(()=>{ timerCountdown?timerSeconds--:timerSeconds++; updateTimerDisplay(); },1000);
});
document.getElementById('timer-pause').addEventListener('click', () => {
  clearInterval(timerInterval); timerInterval=null;
  document.getElementById('timer-start').classList.remove('active');
});
document.getElementById('timer-reset').addEventListener('click', () => {
  clearInterval(timerInterval); timerInterval=null; timerSeconds=0; timerCountdown=false;
  document.getElementById('timer-start').classList.remove('active');
  updateTimerDisplay();
});
updateTimerDisplay();

// ─── Calendar ─────────────────────────────────────────────────────────────
let calYear=new Date().getFullYear(), calMonth=new Date().getMonth();
function renderCal() {
  document.getElementById('cal-month-label').textContent=`${MONTHS_NL[calMonth].slice(0,3)} ${calYear}`;
  const grid=document.getElementById('cal-grid');
  grid.innerHTML='';
  ['ma','di','wo','do','vr','za','zo'].forEach(d=>{const el=document.createElement('div');el.className='cal-dow';el.textContent=d;grid.appendChild(el);});
  const first=new Date(calYear,calMonth,1);
  const startDow=(first.getDay()+6)%7;
  const totalDays=new Date(calYear,calMonth+1,0).getDate();
  const today=new Date();
  const prevDays=new Date(calYear,calMonth,0).getDate();
  for(let i=0;i<startDow;i++){const el=document.createElement('div');el.className='cal-day other-month';el.textContent=prevDays-startDow+1+i;grid.appendChild(el);}
  for(let d=1;d<=totalDays;d++){const el=document.createElement('div');el.className='cal-day';if(d===today.getDate()&&calMonth===today.getMonth()&&calYear===today.getFullYear())el.classList.add('today');el.textContent=d;grid.appendChild(el);}
  const rem=42-startDow-totalDays;
  for(let d=1;d<=rem;d++){const el=document.createElement('div');el.className='cal-day other-month';el.textContent=d;grid.appendChild(el);}
}
document.getElementById('cal-prev').addEventListener('click',()=>{calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderCal();});
document.getElementById('cal-next').addEventListener('click',()=>{calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderCal();});
renderCal();

// ─── Weather ──────────────────────────────────────────────────────────────
function wxEmoji(c){if(c===0)return'☀️';if(c<=2)return'⛅';if(c<=3)return'☁️';if(c<=48)return'🌫️';if(c<=57)return'🌦️';if(c<=67)return'🌧️';if(c<=77)return'🌨️';if(c<=82)return'🌦️';if(c<=86)return'❄️';if(c<=99)return'⛈️';return'🌡️';}
function wxDesc(c){if(c===0)return'Helder';if(c<=1)return'Overwegend helder';if(c<=2)return'Gedeeltelijk bewolkt';if(c<=3)return'Bewolkt';if(c<=45)return'Mistig';if(c<=57)return'Motregen';if(c<=67)return'Regen';if(c<=77)return'Sneeuw';if(c<=82)return'Regenbuien';if(c<=86)return'Sneeuwbuien';if(c<=99)return'Onweer';return'Onbekend';}

function showWeatherData(wx, cityName) {
  const c=wx.current;
  document.getElementById('weather-icon').textContent=wxEmoji(c.weather_code);
  document.getElementById('weather-temp').textContent=Math.round(c.temperature_2m)+'°C';
  document.getElementById('weather-desc').textContent=wxDesc(c.weather_code);
  document.getElementById('weather-loc').textContent=cityName;
  document.getElementById('wh').textContent=c.relative_humidity_2m+'%';
  document.getElementById('ww').textContent=Math.round(c.wind_speed_10m)+' km/h';
  document.getElementById('wf').textContent=Math.round(c.apparent_temperature)+'°C';
  document.getElementById('weather-loading').style.display='none';
  document.getElementById('weather-error').style.display='none';
  document.getElementById('weather-content').style.display='block';
  try{localStorage.setItem('dash_weather_city',cityName);}catch{}
}
function showWeatherError(msg) {
  document.getElementById('weather-loading').style.display='none';
  document.getElementById('weather-content').style.display='none';
  const e=document.getElementById('weather-error');
  e.style.display='block'; e.textContent=msg;
}
async function fetchWeatherCoords(lat,lon,city) {
  try {
    const r=await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m&wind_speed_unit=kmh&timezone=auto`);
    showWeatherData(await r.json(), city);
  } catch { showWeatherError('Kon weerdata niet laden.'); }
}
async function loadWeatherByCity() {
  const input=document.getElementById('weather-loc-input');
  const city=input.value.trim(); if(!city) return;
  document.getElementById('weather-loading').style.display='block';
  document.getElementById('weather-loading').textContent='Zoeken…';
  document.getElementById('weather-content').style.display='none';
  document.getElementById('weather-error').style.display='none';
  try {
    const r=await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(city)}&format=json&limit=1`);
    const geo=await r.json();
    if(!geo.length){showWeatherError(`"${city}" niet gevonden.`);return;}
    input.value='';
    await fetchWeatherCoords(parseFloat(geo[0].lat),parseFloat(geo[0].lon),geo[0].display_name.split(',')[0]);
  } catch { showWeatherError('Zoeken mislukt.'); }
}
document.getElementById('weather-loc-input').addEventListener('keydown',e=>{if(e.key==='Enter')loadWeatherByCity();});

async function loadWeather() {
  try{const saved=localStorage.getItem('dash_weather_city');if(saved){document.getElementById('weather-loc-input').value=saved;await loadWeatherByCity();return;}}catch{}
  if(!navigator.geolocation){showWeatherError('Vul een stad in.');return;}
  navigator.geolocation.getCurrentPosition(
    async pos=>{
      try{const r=await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${pos.coords.latitude}&lon=${pos.coords.longitude}&format=json`);const g=await r.json();const city=g.address?.city||g.address?.town||g.address?.village||'Jouw locatie';await fetchWeatherCoords(pos.coords.latitude,pos.coords.longitude,city);}catch{await fetchWeatherCoords(pos.coords.latitude,pos.coords.longitude,'Jouw locatie');}
    },
    ()=>showWeatherError('Vul een stad of postcode in.'),
    {timeout:6000}
  );
}
loadWeather();

// ─── Snelnotitie ──────────────────────────────────────────────────────────
const QN_KEY = 'dash_quicknote';
let qnSaveTimer = null;

function initQuicknote() {
  const ta = document.getElementById('quicknote-text');
  const chars = document.getElementById('quicknote-chars');
  const saved = document.getElementById('quicknote-saved');

  // Load saved text
  try { ta.value = localStorage.getItem(QN_KEY) || ''; } catch {}
  chars.textContent = ta.value.length + ' tekens';

  ta.addEventListener('input', () => {
    chars.textContent = ta.value.length + ' tekens';
    saved.classList.remove('show');
    clearTimeout(qnSaveTimer);
    qnSaveTimer = setTimeout(() => {
      try { localStorage.setItem(QN_KEY, ta.value); } catch {}
      saved.classList.add('show');
      setTimeout(() => saved.classList.remove('show'), 2000);
    }, 600);
  });
}

// ─── Export / Import ──────────────────────────────────────────────────────
function openExIm() {
  // Refresh export textarea with current data
  const exportData = {
    version: 4,
    exported: new Date().toISOString(),
    data: data,
    quicknote: document.getElementById('quicknote-text')?.value || ''
  };
  document.getElementById('exim-export-text').value = JSON.stringify(exportData, null, 2);
  document.getElementById('exim-export-status').textContent = '';
  document.getElementById('exim-import-status').textContent = '';
  document.getElementById('exim-import-text').value = '';
  switchEximTab('export');
  document.getElementById('exim-modal').classList.remove('hidden');
}

function closeExIm() { document.getElementById('exim-modal').classList.add('hidden'); }
document.getElementById('exim-modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeExIm(); });

function switchEximTab(tab) {
  document.querySelectorAll('.exim-tab').forEach((t,i) => t.classList.toggle('active', (i===0&&tab==='export')||(i===1&&tab==='import')));
  document.getElementById('exim-export').classList.toggle('active', tab==='export');
  document.getElementById('exim-import').classList.toggle('active', tab==='import');
}

function copyExport() {
  const txt = document.getElementById('exim-export-text').value;
  navigator.clipboard.writeText(txt).then(() => {
    const s = document.getElementById('exim-export-status');
    s.className = 'exim-status ok'; s.textContent = '✓ Gekopieerd naar klembord!';
    setTimeout(() => s.textContent = '', 3000);
  }).catch(() => {
    document.getElementById('exim-export-text').select();
    document.execCommand('copy');
    const s = document.getElementById('exim-export-status');
    s.className = 'exim-status ok'; s.textContent = '✓ Gekopieerd!';
    setTimeout(() => s.textContent = '', 3000);
  });
}

function downloadExport() {
  const txt = document.getElementById('exim-export-text').value;
  const date = new Date().toISOString().slice(0,10);
  const blob = new Blob([txt], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `dashboard-backup-${date}.json`;
  a.click();
  URL.revokeObjectURL(a.href);
}

function loadImportFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('exim-import-text').value = e.target.result;
    document.getElementById('exim-import-status').className = 'exim-status';
    document.getElementById('exim-import-status').textContent = `📄 Bestand geladen: ${file.name}`;
  };
  reader.readAsText(file);
  event.target.value = ''; // reset so same file can be reloaded
}

function doImport() {
  const txt = document.getElementById('exim-import-text').value.trim();
  const s = document.getElementById('exim-import-status');
  if (!txt) { s.className='exim-status err'; s.textContent='⚠ Geen data om te importeren.'; return; }
  try {
    const parsed = JSON.parse(txt);
    // Accept both wrapped format (with .data) and raw data format
    const imported = parsed.data || parsed;
    if (!imported.tabs || !Array.isArray(imported.tabs)) throw new Error('Ongeldig formaat: geen tabs gevonden.');
    if (!imported.notes || !Array.isArray(imported.notes)) imported.notes = [];
    // Restore quicknote if present
    if (parsed.quicknote !== undefined) {
      try { localStorage.setItem('dash_quicknote', parsed.quicknote); } catch {}
      const qn = document.getElementById('quicknote-text');
      if (qn) { qn.value = parsed.quicknote; document.getElementById('quicknote-chars').textContent = parsed.quicknote.length + ' tekens'; }
    }
    data = imported;
    save();
    renderBlocks();
    renderNotes();
    s.className = 'exim-status ok';
    s.textContent = '✓ Import geslaagd! Alle data is hersteld.';
    setTimeout(() => closeExIm(), 1800);
  } catch(e) {
    s.className = 'exim-status err';
    s.textContent = '✗ Fout: ' + e.message;
  }
}

// ─── Init ──────────────────────────────────────────────────────────────────
renderBlocks();
renderNotes();
initQuicknote();
</script>
