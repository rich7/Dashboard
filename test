<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Persoonlijk Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>
<style>
  :root {
    --bg: #0f1117; --bg2: #181b24; --bg3: #1e2130; --bg4: #252840;
    --accent: #6c8fff; --accent2: #a78bfa; --accent3: #34d399;
    --text: #e8eaf0; --text2: #9aa0b8; --text3: #5a6080;
    --border: #2a2f47; --border2: #353a58;
    --danger: #f87171; --warning: #fbbf24;
    --radius: 10px; --radius2: 14px;
    --font: 'DM Sans', sans-serif; --mono: 'DM Mono', monospace;
    --shadow: 0 2px 16px rgba(0,0,0,0.35);
    --widget-col: 260px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; font-size: 16px; line-height: 1.5; }

  /* ── Header ── */
  .header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 24px; background: var(--bg2); border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 100;
  }
  .header-left { display: flex; align-items: center; gap: 20px; }
  .logo { font-size: 18px; font-weight: 600; color: var(--accent); letter-spacing: -0.3px; }
  .tabs { display: flex; gap: 4px; }
  .tab {
    padding: 6px 16px; border-radius: 7px; border: 1px solid transparent;
    background: transparent; color: var(--text2); font-family: var(--font);
    font-size: 15px; font-weight: 500; cursor: pointer; transition: all 0.15s;
  }
  .tab:hover { color: var(--text); background: var(--bg3); }
  .tab.active { background: var(--bg4); border-color: var(--border2); color: var(--text); }
  #datetime-mini { font-family: var(--mono); font-size: 13px; color: var(--text3); text-align: right; line-height: 1.4; }

  /* ── Layout ── */
  .page-layout {
    display: flex;
    min-height: calc(100vh - 57px);
  }

  /* Left: main content */
  .content-area {
    flex: 1;
    padding: 20px 24px;
    min-width: 0;
  }

  /* Right: widget column — only shown on tab 0 */
  .widget-col {
    width: var(--widget-col);
    flex-shrink: 0;
    padding: 16px 12px 16px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-left: 1px solid var(--border);
    background: var(--bg);
  }
  .widget-col.hidden { display: none; }

  /* ── Tab panels ── */
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* ── Widget cards ── */
  .widget-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    overflow: hidden;
    position: relative;
    transition: border-color 0.15s;
  }
  .widget-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
  }
  .widget-card:hover { border-color: var(--border2); }

  .widget-label {
    font-size: 11px; letter-spacing: 0.8px; text-transform: uppercase;
    color: var(--text3); font-weight: 500; margin-bottom: 8px; display: block;
  }
  .widget-body { padding: 14px 14px 14px; }

  /* ── Clock ── */
  #clock-time { font-family: var(--mono); font-size: 34px; font-weight: 500; color: var(--text); letter-spacing: 2px; }
  #clock-date { font-size: 13px; color: var(--text2); margin-top: 4px; }

  /* ── Timer ── */
  #timer-display { font-family: var(--mono); font-size: 30px; color: var(--text); letter-spacing: 2px; }
  .timer-btns { display: flex; gap: 5px; margin-top: 8px; flex-wrap: wrap; }
  .btn-xs {
    padding: 5px 9px; border-radius: 6px; border: 1px solid var(--border2);
    background: var(--bg3); color: var(--text2); font-size: 13px;
    font-family: var(--font); cursor: pointer; transition: all 0.15s;
  }
  .btn-xs:hover { color: var(--text); border-color: var(--accent); }
  .btn-xs.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  #timer-preset { font-size: 13px; color: var(--text3); margin-top: 8px; }
  .preset-btn {
    background: none; border: none; color: var(--accent); cursor: pointer;
    font-size: 13px; font-family: var(--font); padding: 0 3px;
    text-decoration: underline; text-underline-offset: 2px;
  }
  .preset-btn:hover { color: var(--accent2); }
  .timer-custom { display: flex; gap: 4px; margin-top: 6px; align-items: center; }
  .timer-custom-input {
    width: 48px; background: var(--bg3); border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); font-family: var(--mono); font-size: 13px; padding: 4px 4px;
    outline: none; text-align: center; transition: border-color 0.15s;
  }
  .timer-custom-input:focus { border-color: var(--accent); }
  .timer-custom-sep { color: var(--text3); font-size: 14px; font-weight: 600; }

  /* ── Calendar ── */
  .cal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
  .cal-nav { background: none; border: none; color: var(--text2); cursor: pointer; font-size: 16px; padding: 2px 5px; border-radius: 4px; transition: color 0.15s; }
  .cal-nav:hover { color: var(--text); }
  #cal-month-label { font-size: 14px; font-weight: 500; color: var(--text); }
  .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; text-align: center; }
  .cal-dow { font-size: 11px; color: var(--text3); font-weight: 500; padding: 2px 0 3px; }
  .cal-day { font-size: 12px; padding: 3px 1px; border-radius: 4px; color: var(--text2); cursor: default; transition: background 0.1s; }
  .cal-day.other-month { color: var(--text3); }
  .cal-day.today { background: var(--accent); color: #fff; font-weight: 600; border-radius: 5px; }
  .cal-day:not(.today):hover { background: var(--bg3); color: var(--text); }

  /* ── Weather ── */
  #weather-main { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
  #weather-icon { font-size: 30px; }
  #weather-temp { font-size: 30px; font-weight: 500; color: var(--text); }
  #weather-desc { font-size: 14px; color: var(--text2); }
  #weather-loc { font-size: 12px; color: var(--text3); margin-top: 2px; }
  #weather-details { display: flex; gap: 10px; margin-top: 8px; flex-wrap: wrap; }
  .weather-detail { font-size: 12px; color: var(--text2); line-height: 1.6; }
  .weather-detail span { color: var(--text3); display: block; }
  #weather-loading { font-size: 14px; color: var(--text3); }
  #weather-error { font-size: 13px; color: var(--danger); }
  .weather-loc-form { display: flex; gap: 5px; margin-top: 10px; }
  .weather-loc-input {
    flex: 1; background: var(--bg3); border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); font-family: var(--font); font-size: 13px; padding: 5px 8px; outline: none; transition: border-color 0.15s;
  }
  .weather-loc-input:focus { border-color: var(--accent); }
  .weather-loc-input::placeholder { color: var(--text3); }
  .weather-loc-btn {
    padding: 5px 9px; border-radius: 6px; border: 1px solid var(--border2);
    background: var(--bg4); color: var(--text2); font-size: 13px; font-family: var(--font);
    cursor: pointer; transition: all 0.15s;
  }
  .weather-loc-btn:hover { color: var(--text); border-color: var(--accent); }

  /* ── Link Blocks Grid ── */
  .blocks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .link-block {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--radius2); overflow: hidden; transition: border-color 0.15s;
  }
  .link-block:hover { border-color: var(--border2); }
  .block-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 9px 12px 7px; border-bottom: 1px solid var(--border); background: var(--bg3);
  }
  .block-title-wrap { display: flex; align-items: center; gap: 6px; flex: 1; min-width: 0; }
  .drag-handle {
    cursor: grab; color: var(--text3); font-size: 12px; padding: 0 2px 0 0;
    flex-shrink: 0; opacity: 0; transition: opacity 0.15s; user-select: none;
  }
  .drag-handle:active { cursor: grabbing; }
  .link-block:hover .drag-handle { opacity: 1; }
  .block-emoji { font-size: 15px; flex-shrink: 0; }
  .block-title { font-weight: 600; font-size: 14px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .block-actions { display: flex; gap: 3px; flex-shrink: 0; }
  .btn-icon {
    background: none; border: 1px solid transparent; color: var(--text3);
    cursor: pointer; font-size: 13px; font-family: var(--font); padding: 3px 8px;
    border-radius: 5px; transition: all 0.15s; white-space: nowrap;
  }
  .btn-icon:hover { color: var(--text); border-color: var(--border2); background: var(--bg4); }
  .btn-icon.open-all { color: var(--accent); }
  .btn-icon.open-all:hover { border-color: var(--accent); background: rgba(108,143,255,0.1); }
  .block-links { padding: 4px 0; }
  .link-item {
    display: flex; align-items: center; padding: 6px 12px; gap: 8px;
    text-decoration: none; color: var(--text2); font-size: 14px;
    transition: all 0.12s; border-radius: 4px; margin: 1px 5px;
  }
  .link-item:hover { background: var(--bg3); color: var(--text); }
  .link-item-favicon { width: 16px; height: 16px; border-radius: 2px; flex-shrink: 0; opacity: 0.8; }
  .link-item-name { flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .add-first-link { padding: 10px 12px; font-size: 13px; color: var(--text3); font-style: italic; text-align: center; }

  .link-block.sortable-chosen { opacity: 0.85; box-shadow: 0 8px 32px rgba(0,0,0,0.5); border-color: var(--accent) !important; }
  .link-block.sortable-ghost { opacity: 0.25; }

  .add-block-btn {
    background: var(--bg2); border: 1px dashed var(--border2); border-radius: var(--radius2);
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 22px 14px; color: var(--text3); cursor: pointer; font-size: 13px;
    font-family: var(--font); transition: all 0.15s; width: 100%;
  }
  .add-block-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(108,143,255,0.04); }

  .section-title {
    font-size: 11px; letter-spacing: 0.8px; text-transform: uppercase;
    color: var(--text3); font-weight: 500; margin-bottom: 10px;
  }

  /* ── Notes ── */
  .notes-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px; }
  .note-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius2); overflow: hidden; display: flex; flex-direction: column; }
  .note-header { display: flex; align-items: center; justify-content: space-between; padding: 10px 14px; background: var(--bg3); border-bottom: 1px solid var(--border); }
  .note-title-input { background: none; border: none; color: var(--text); font-family: var(--font); font-size: 14px; font-weight: 600; flex: 1; outline: none; min-width: 0; }
  .note-title-input::placeholder { color: var(--text3); }
  .note-textarea { flex: 1; background: none; border: none; color: var(--text2); font-family: var(--font); font-size: 15px; padding: 12px 14px; outline: none; resize: none; min-height: 120px; line-height: 1.6; }
  .note-textarea::placeholder { color: var(--text3); }
  .note-footer { padding: 6px 14px; font-size: 12px; color: var(--text3); border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .btn-del-note { background: none; border: none; color: var(--text3); cursor: pointer; font-size: 13px; font-family: var(--font); padding: 2px 6px; border-radius: 4px; transition: all 0.15s; }
  .btn-del-note:hover { color: var(--danger); background: rgba(248,113,113,0.1); }
  .add-note-btn {
    background: var(--bg2); border: 1px dashed var(--border2); border-radius: var(--radius2);
    display: flex; align-items: center; justify-content: center; gap: 8px;
    padding: 22px 14px; color: var(--text3); cursor: pointer; font-size: 13px;
    font-family: var(--font); transition: all 0.15s; width: 100%;
  }
  .add-note-btn:hover { border-color: var(--accent3); color: var(--accent3); background: rgba(52,211,153,0.04); }

  /* ── Modal ── */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); z-index: 500; display: flex; align-items: center; justify-content: center; padding: 20px; }
  .modal-overlay.hidden { display: none; }
  .modal { background: var(--bg2); border: 1px solid var(--border2); border-radius: 16px; width: 100%; max-width: 480px; max-height: 80vh; overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 20px 60px rgba(0,0,0,0.6); }
  .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; border-bottom: 1px solid var(--border); }
  .modal-title { font-size: 16px; font-weight: 600; color: var(--text); }
  .modal-close { background: none; border: none; color: var(--text2); cursor: pointer; font-size: 20px; line-height: 1; padding: 4px; transition: color 0.15s; }
  .modal-close:hover { color: var(--text); }
  .modal-body { padding: 16px 20px; overflow-y: auto; flex: 1; }
  .form-group { margin-bottom: 14px; }
  .form-label { display: block; font-size: 12px; color: var(--text2); margin-bottom: 5px; font-weight: 500; letter-spacing: 0.4px; }
  .form-input { width: 100%; background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-family: var(--font); font-size: 15px; padding: 8px 12px; outline: none; transition: border-color 0.15s; }
  .form-input:focus { border-color: var(--accent); }
  .form-input::placeholder { color: var(--text3); }
  .link-edit-list { margin-top: 6px; }
  .link-edit-item { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; padding: 6px 8px; background: var(--bg3); border: 1px solid var(--border); border-radius: var(--radius); }
  .link-edit-item input { flex: 1; background: none; border: none; color: var(--text); font-family: var(--font); font-size: 14px; outline: none; min-width: 0; }
  .link-edit-item input::placeholder { color: var(--text3); }
  .link-edit-item input:first-child { max-width: 120px; border-right: 1px solid var(--border); padding-right: 6px; }
  .btn-del-link { background: none; border: none; color: var(--text3); cursor: pointer; font-size: 16px; line-height: 1; padding: 2px 4px; border-radius: 3px; transition: color 0.15s; }
  .btn-del-link:hover { color: var(--danger); }
  .btn-add-link { width: 100%; padding: 8px; border-radius: var(--radius); background: none; border: 1px dashed var(--border2); color: var(--text3); cursor: pointer; font-size: 14px; font-family: var(--font); transition: all 0.15s; margin-bottom: 4px; }
  .btn-add-link:hover { color: var(--accent); border-color: var(--accent); }
  .modal-footer { display: flex; gap: 8px; justify-content: flex-end; padding: 14px 20px; border-top: 1px solid var(--border); }
  .btn-cancel { padding: 8px 18px; border-radius: var(--radius); border: 1px solid var(--border2); background: none; color: var(--text2); cursor: pointer; font-size: 15px; font-family: var(--font); transition: all 0.15s; }
  .btn-cancel:hover { color: var(--text); background: var(--bg3); }
  .btn-save { padding: 8px 20px; border-radius: var(--radius); border: none; background: var(--accent); color: #fff; cursor: pointer; font-size: 15px; font-weight: 500; font-family: var(--font); transition: opacity 0.15s; }
  .btn-save:hover { opacity: 0.85; }
  .btn-danger { padding: 8px 14px; border-radius: var(--radius); border: 1px solid rgba(248,113,113,0.3); background: none; color: var(--danger); cursor: pointer; font-size: 14px; font-family: var(--font); transition: all 0.15s; margin-right: auto; }
  .btn-danger:hover { background: rgba(248,113,113,0.1); }

  /* ── Export / Import ── */
  .btn-exim {
    padding: 6px 13px; border-radius: 7px; border: 1px solid var(--border2);
    background: var(--bg3); color: var(--text2); font-family: var(--font);
    font-size: 13px; cursor: pointer; transition: all 0.15s; white-space: nowrap;
  }
  .btn-exim:hover { color: var(--text); border-color: var(--accent); background: var(--bg4); }

  .exim-modal { max-width: 540px; }
  .exim-tabs { display: flex; gap: 4px; margin-bottom: 14px; }
  .exim-tab {
    padding: 6px 14px; border-radius: 6px; border: 1px solid transparent;
    background: none; color: var(--text2); font-family: var(--font);
    font-size: 13px; cursor: pointer; transition: all 0.15s;
  }
  .exim-tab.active { background: var(--bg4); border-color: var(--border2); color: var(--text); }
  .exim-tab:hover:not(.active) { background: var(--bg3); color: var(--text); }
  .exim-section { display: none; }
  .exim-section.active { display: block; }
  .exim-textarea {
    width: 100%; height: 200px; background: var(--bg3); border: 1px solid var(--border);
    border-radius: 8px; color: var(--text2); font-family: var(--mono); font-size: 12px;
    padding: 10px 12px; outline: none; resize: vertical; transition: border-color 0.15s; line-height: 1.5;
  }
  .exim-textarea:focus { border-color: var(--accent); }
  .exim-hint { font-size: 12px; color: var(--text3); margin-bottom: 8px; line-height: 1.5; }
  .exim-status { font-size: 13px; margin-top: 8px; min-height: 20px; }
  .exim-status.ok { color: var(--accent3); }
  .exim-status.err { color: var(--danger); }
  .btn-full { width: 100%; padding: 9px; border-radius: var(--radius); border: 1px solid var(--border2); background: var(--bg3); color: var(--text2); font-family: var(--font); font-size: 14px; cursor: pointer; transition: all 0.15s; margin-bottom: 8px; text-align: left; }
  .btn-full:hover { border-color: var(--accent); color: var(--text); background: var(--bg4); }
  .btn-full.primary { background: var(--accent); border-color: var(--accent); color: #fff; font-weight: 500; }
  .btn-full.primary:hover { opacity: 0.85; }

  /* ── Snelnotitie widget ── */
  .quicknote-textarea {
    width: 100%; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px;
    color: var(--text2); font-family: var(--font); font-size: 14px; line-height: 1.6;
    padding: 8px 10px; resize: none; outline: none; min-height: 90px;
    transition: border-color 0.15s; display: block;
  }
  .quicknote-textarea:focus { border-color: var(--accent); color: var(--text); }
  .quicknote-textarea::placeholder { color: var(--text3); }
  .quicknote-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 6px; font-size: 12px; color: var(--text3); }
  .quicknote-saved { opacity: 0; transition: opacity 0.4s; font-size: 12px; color: var(--accent3); }
  .quicknote-saved.show { opacity: 1; }

  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text3); }
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <div class="logo">⬡ Dashboard</div>
    <div class="tabs" id="tab-bar">
      <button class="tab active" data-tab="0">Favorieten + Widgets</button>
      <button class="tab" data-tab="1">Favorieten</button>
      <button class="tab" data-tab="2">Notities</button>
    </div>
  </div>
  <div class="header-right">
    <button class="btn-exim" onclick="openExIm()">⬍ Export / Import</button>
    <div id="datetime-mini"></div>
  </div>
</div>

<div class="page-layout">

  <div class="content-area">

    <!-- TAB 0 -->
    <div class="tab-panel active" id="panel-0">
      <div class="section-title">Links</div>
      <div class="blocks-grid" id="grid-0"></div>
      <div style="margin-top:12px">
        <button class="add-block-btn" onclick="openAddBlock(0)">＋ Nieuw blok toevoegen</button>
      </div>
    </div>

    <!-- TAB 1 -->
    <div class="tab-panel" id="panel-1">
      <div class="section-title">Links</div>
      <div class="blocks-grid" id="grid-1"></div>
      <div style="margin-top:12px">
        <button class="add-block-btn" onclick="openAddBlock(1)">＋ Nieuw blok toevoegen</button>
      </div>
    </div>

    <!-- TAB 2 -->
    <div class="tab-panel" id="panel-2">
      <div class="section-title">Notities</div>
      <div class="notes-grid" id="notes-grid"></div>
      <div style="margin-top:12px">
        <button class="add-note-btn" onclick="addNote()">＋ Nieuwe notitie</button>
      </div>
    </div>

  </div><!-- /content-area -->

  <!-- Widget column (right side, tab 0 only) -->
  <div class="widget-col" id="widget-col">

    <div class="widget-card" id="clock-widget">
      <div class="widget-body">
        <span class="widget-label">Klok</span>
        <div id="clock-time">00:00</div>
        <div id="clock-date"></div>
      </div>
    </div>

    <div class="widget-card" id="timer-widget">
      <div class="widget-body">
        <span class="widget-label">Timer</span>
        <div id="timer-display">00:00</div>
        <div class="timer-btns">
          <button class="btn-xs" id="timer-start">▶ Start</button>
          <button class="btn-xs" id="timer-pause">⏸ Pauze</button>
          <button class="btn-xs" id="timer-reset">↺ Reset</button>
        </div>
        <div id="timer-preset">
